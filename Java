function fetchStats() {
  fetch(API + '/stats')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var el = document.getElementById('stat-total');
      if (el) el.textContent = Number(d.total_listings).toLocaleString();
      var el2 = document.getElementById('stat-sources');
      if (el2) el2.textContent = d.total_sources;
      if (d.trending && d.trending.length) {
        var html = d.trending.map(function(item) {
          return '<div style="display:flex;justify-content:space-between;padding:11px 0;border-bottom:0.5px solid var(--cream3)">' +
            '<span style="font-size:13px">' + item.neighborhood + '</span>' +
            '<span style="font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--olive)">' + item.count + ' ' + tr('trendNew') + '</span>' +
            '</div>';
        }).join('');
        var tel = document.getElementById('trending');
        if (tel) tel.innerHTML = html;
      }
    })
    .catch(function() {
      var el = document.getElementById('stat-total');
      if (el) el.textContent = '2,841';
      var el2 = document.getElementById('stat-sources');
      if (el2) el2.textContent = '7';
    });
}

function doSearch(reset) {
  if (reset === undefined) reset = true;
  if (reset) offset = 0;
  var hood = document.getElementById('s-hood').value;
  var price = document.getElementById('s-price').value;
  var rooms = document.getElementById('s-rooms').value || curRooms;
  var url = API + '/listings?limit=6&offset=' + offset + '&sort=' + curSort;
  if (hood) url += '&neighborhood=' + encodeURIComponent(hood);
  if (price) url += '&max_price=' + price;
  if (rooms && rooms !== 'new') url += '&rooms=' + rooms;
  if (newOnly || rooms === 'new') url += '&new_today=true';
  fetch(url)
    .then(function(r) { return r.json(); })
    .then(function(d) {
      renderListings(d.listings, reset);
      var shown = Math.min(offset + 6, d.total);
      var el = document.getElementById('listing-count');
      if (el) el.textContent = tr('showing') + ' ' + shown + ' ' + tr('of') + ' ' + Number(d.total).toLocaleString();
    })
    .catch(function() { renderFallback(); });
}

