function renderFallback() {
  var list = fallback.map(function(l) {
    return {id:l.id, neighborhood: lang==='he'?l.nHE:l.nEN, title: lang==='he'?l.tHE:l.tEN,
      rooms:l.rooms, sqm:l.sqm, floor:l.floor, price:l.price, source:l.source, url:l.url, created_at:new Date()};
  });
  renderListings(list, true);
  var el = document.getElementById('listing-count');
  if (el) el.textContent = tr('showing') + ' 6 ' + tr('of') + ' 2,841';
  var el2 = document.getElementById('stat-total');
  if (el2) el2.textContent = '2,841';
  var el3 = document.getElementById('stat-sources');
  if (el3) el3.textContent = '7';
}

function renderListings(list, reset) {
  var g = document.getElementById('listings-grid');
  if (!g) return;
  var now = Date.now();
  var html = list.map(function(l) {
    var sv = saved.has(l.id);
    var isNew = new Date(l.created_at) > new Date(now - 86400000);
    var card = '<div class="listing-card" onclick="if(!event.target.classList.contains('listing-save'))window.open('' + l.url + '','_blank')">';
    card += '<div class="listing-img">';
    card += '<span class="img-placeholder">' + l.neighborhood + '</span>';
    card += '<div class="listing-source-badge">' + l.source + '</div>';
    card += '<div class="listing-save' + (sv ? ' saved' : '') + '" onclick="event.stopPropagation();toggleSave('' + l.id + '')">' + (sv ? '&#9829;' : '&#9825;') + '</div>';
    if (isNew) card += '<div class="new-badge">' + tr('newBadge') + '</div>';
    card += '</div>';
    card += '<div class="listing-body">';
    card += '<p class="listing-neighborhood">' + l.neighborhood + '</p>';
    card += '<p class="listing-name">' + l.title + '</p>';
    card += '<div class="listing-details">';
    card += '<span>' + l.rooms + ' ' + tr('rooms') + '</span>';
    if (l.sqm) card += '<span>' + l.sqm + ' m&#178;</span>';
    if (l.floor) card += '<span>' + tr('floor') + ' ' + l.floor + '</span>';
    card += '</div>';
    card += '<div style="display:flex;align-items:baseline;gap:6px">';
    card += '<span class="price-amount">&#8362;' + Number(l.price).toLocaleString() + '</span>';
    card += '<span class="price-period">' + tr('perMonth') + '</span>';
    card += '</div></div></div>';
    return card;
  }).join('');
  if (reset) {
    g.innerHTML = html || '<div style="padding:40px;text-align:center;color:var(--text-muted);font-size:18px;grid-column:1/-1">' + tr('noListings') + '</div>';
  } else {
    g.innerHTML += html;
  }
}

function toggleSave(id) {
  if (saved.has(id)) saved.delete(id); else saved.add(id);
  localStorage.setItem('b_saved', JSON.stringify(Array.from(saved)));
  doSearch(false);
}

function setRooms(btn, rooms) {
  document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  curRooms = rooms;
  newOnly = rooms === 'new';
  doSearch(true);
}

function loadMore() { offset += 6; doSearch(false); }

function openPost() { document.getElementById('post-overlay').style.display = 'block'; document.body.style.overflow = 'hidden'; }
function closePost() { document.getElementById('post-overlay').style.display = 'none'; document.body.style.overflow = ''; var ps = document.getElementById('post-success'); if(ps) ps.style.display='none'; var pf = document.getElementById('post-form-inner'); if(pf) pf.style.display='block'; }

function submitPost() {
  var name = document.getElementById('f-name').value.trim();
  var title = document.getElementById('f-title').value.trim();
  var hood = document.getElementById('f-hood').value.trim();
  var price = document.getElementById('f-price').value;
  var err = document.getElementById('post-err');
  if (!name || !title || !hood || !price) {
    if (err) { err.style.display = 'block'; err.textContent = tr('fillFields'); }
    return;
  }
  if (err) err.style.display = 'none';
  fetch(API + '/listings/post', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      title: title, neighborhood: hood, price: parseInt(price),
      rooms: parseFloat(document.getElementById('f-rooms').value) || 0,
      sqm: parseInt(document.getElementById('f-sqm').value) || 0,
      floor: parseInt(document.getElementById('f-floor').value) || 0,
      description: document.getElementById('f-desc').value,
      contact_name: name,
      contact_phone: document.getElementById('f-phone').value
    })
  }).catch(function() {});
  var pf = document.getElementById('post-form-inner');
  var ps = document.getElementById('post-success');
  if (pf) pf.style.display = 'none';
  if (ps) ps.style.display = 'block';
  doSearch(true);
}

document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.filter-tag').forEach(function(tag) {
    tag.addEventListener('click', function() { tag.classList.toggle('active'); doSearch(true); });
  });
  applyTranslations();
  fetchStats();
  doSearch(true);
});
